---
interface Props {
	src: string;
	title: string;
	className?: string;
}

const { src, title, className = "" } = Astro.props;
---

<div class={`relative w-full aspect-video rounded-2xl overflow-hidden glass border border-white/10 group ${className}`}>
	<div class="absolute inset-0 bg-brand-dark/20 flex items-center justify-center opacity-100 group-data-[loaded=true]:opacity-0 transition-opacity pointer-events-none">
		<div class="flex flex-col items-center gap-4">
			<div class="w-12 h-12 border-4 border-brand-primary border-t-transparent rounded-full animate-spin"></div>
			<p class="text-slate-400 font-medium">Cargando visualización...</p>
		</div>
	</div>
	
	<iframe
		title={title}
		src={src}
		class="w-full h-full border-0 opacity-0 transition-opacity duration-700"
		allowFullScreen={true}
		onload="this.parentElement.setAttribute('data-loaded', 'true'); this.classList.remove('opacity-0')"
	></iframe>
</div>

<style>
	iframe {
		filter: contrast(1.1) saturate(1.1);
	}
</style>
