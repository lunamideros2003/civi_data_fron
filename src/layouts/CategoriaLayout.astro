---
import Base from './Base.astro';
import RagAssistant from '../components/RagAssistant.tsx';
import { 
	LucideLayoutDashboard, 
	LucidePieChart,
	LucideMap,
	LucideBarChart3,
	LucideFileSignature,
	LucideBriefcase,
	LucideArrowLeft,
	LucideHome
} from 'lucide-react';

interface Props {
	title: string;
	category: string;
	heroImage?: string;
}

const { title, category, heroImage } = Astro.props;

const menuItems = [
	{ name: 'Vista General', icon: LucideLayoutDashboard, href: `/contratos/vista-general` },
	{ name: 'Por Modalidad', icon: LucidePieChart, href: `/contratos/por-modalidad` },
	{ name: 'Por Departamento', icon: LucideMap, href: `/contratos/por-departamento` },
	{ name: 'Distribución por Valor', icon: LucideBarChart3, href: `/contratos/distribucion-por-valor` },
	{ name: 'Por Tipo de Contrato', icon: LucideFileSignature, href: `/contratos/por-tipo-de-contrato` },
	{ name: 'Entidades Contratantes', icon: LucideBriefcase, href: `/contratos/entidades-contratantes` },
];

const bottomActions = [
	{ name: 'Volver al Inicio', icon: LucideHome, href: '/' }
];
---

<Base title={`${title} | CiviData`}>
	<div class="flex min-h-screen">
		<!-- Sidebar -->
		<aside class="w-64 glass border-r border-white/10 flex-col sticky top-0 h-screen hidden md:flex">
			<div class="p-6">
				<a href="/" class="flex items-center gap-2 group">
					<div class="w-8 h-8 bg-brand-primary rounded-lg flex items-center justify-center group-hover:scale-110 transition-transform">
						<span class="text-white font-bold">C</span>
					</div>
					<span class="text-xl font-heading font-bold">CiviData</span>
				</a>
			</div>
			
			<nav class="flex-1 px-4 py-2 space-y-1">
				{menuItems.map(item => (
					<a 
						href={item.href}
						class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-colors"
					>
						<item.icon size={18} />
						<span>{item.name}</span>
					</a>
				))}

				<div class="pt-4 mt-4 border-t border-white/10 space-y-1">
					{bottomActions.map(item => (
						<a 
							href={item.href}
							class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-brand-primary/20 transition-colors"
						>
							<item.icon size={18} />
							<span>{item.name}</span>
						</a>
					))}
				</div>
			</nav>
			
			<div class="p-4 mt-auto">
				<div class="p-4 rounded-xl bg-gradient-to-br from-brand-primary/20 to-brand-secondary/20 border border-white/10">
					<p class="text-xs text-slate-400 mb-2">Estado de datos</p>
					<div class="flex items-center gap-2">
						<div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
						<span class="text-xs font-medium">Actualizado hoy</span>
					</div>
				</div>
			</div>
		</aside>
		
		<!-- Main Content -->
		<main class="flex-1 flex flex-col">
			<!-- Hero Section -->
			<header class="relative h-64 w-full overflow-hidden flex items-end p-8 md:p-12">
				<div class="absolute inset-0 bg-brand-dark/60 z-10"></div>
				<div 
					class="absolute inset-0 bg-cover bg-center"
					style={`background-image: url(${heroImage || 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=2070'});`}
				></div>
				
				<!-- Gradient Overlay -->
				<div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/40 to-transparent z-20"></div>
				
				<div class="relative z-30 max-w-4xl">
					<a href="/" class="flex items-center gap-2 text-slate-300 hover:text-white mb-4 transition-colors text-sm">
						<LucideArrowLeft size={16} />
						Volver al inicio
					</a>
					<h1 class="text-4xl md:text-5xl font-heading font-black mb-2">{title}</h1>
					<p class="text-slate-300 text-lg max-w-2xl">Visualización detallada de indicadores y métricas clave para el sector de {category.toLowerCase()}.</p>
				</div>
			</header>
			
			<section class="p-6 md:p-12">
				<slot />
			</section>
		</main>
	</div>
	<RagAssistant variant="floating" client:load />
</Base>
