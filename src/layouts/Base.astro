---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import RagAssistant from '../components/RagAssistant';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "CiviData | Observatorio de Datos Públicos", 
	description = "Explora y analiza datos abiertos de contratación, educación y salud en Colombia." 
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
		
		<ClientRouter />
	</head>
	<body>
		<slot />
		<RagAssistant client:load />
		
		<style is:global>
			:root {
				--accent: 136, 58, 234;
				--accent-light: 224, 204, 250;
				--accent-dark: 49, 10, 101;
				--accent-gradient: linear-gradient(
					45deg,
					rgb(var(--accent)),
					rgb(var(--accent-light)) 30%,
					white 60%
				);
			}
			
			/* Custom scrollbar */
			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: #0f172a;
			}
			::-webkit-scrollbar-thumb {
				background: #334155;
				border-radius: 4px;
			}
			::-webkit-scrollbar-thumb:hover {
				background: #475569;
			}
		</style>
	</body>
</html>
