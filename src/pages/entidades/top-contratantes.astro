---
import CategoriaLayout from '../../layouts/CategoriaLayout.astro';
import IframePBI from '../../components/IframePBI.astro';
import FiltroVigencia from '../../components/FiltroVigencia.tsx';

// URL de ejemplo
const pbiUrl = "https://app.powerbi.com/view?r=eyJrIjoiYjYxNjU1MWItZDIzMy00ZDRiLWE4MzMtZjA4N2JiNjI4NDY1IiwidCI6IjY3OTY5NzhhLTFmNDItNDg1Yy1hYjBkLWZkMDVjYmI4Y2M1NCIsImMiOjR9";
---

<CategoriaLayout 
	title="Top Entidades Contratantes" 
	category="Entidades"
>
	<div class="space-y-8">
		<div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
			<div>
				<h2 class="text-3xl font-heading font-bold mb-2">Ranking Institucional</h2>
				<p class="text-slate-400">Análisis de las entidades con mayor presupuesto ejecutado.</p>
			</div>
			<FiltroVigencia client:load />
		</div>
		
		<IframePBI 
			src={pbiUrl} 
			title="Ranking Entidades" 
		/>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<div class="p-6 rounded-2xl glass">
				<h4 class="text-slate-500 text-xs font-bold uppercase mb-2">Entidad #1</h4>
				<p class="text-xl font-bold">Alcaldía Mayor de Bogotá</p>
				<p class="text-brand-primary font-mono text-sm mt-1">$1.2T COP</p>
			</div>
			<div class="p-6 rounded-2xl glass">
				<h4 class="text-slate-500 text-xs font-bold uppercase mb-2">Entidad #2</h4>
				<p class="text-xl font-bold">Min. Transporte</p>
				<p class="text-brand-primary font-mono text-sm mt-1">$850B COP</p>
			</div>
			<div class="p-6 rounded-2xl glass">
				<h4 class="text-slate-500 text-xs font-bold uppercase mb-2">Entidad #3</h4>
				<p class="text-xl font-bold">Gobernación Antioquia</p>
				<p class="text-brand-primary font-mono text-sm mt-1">$720B COP</p>
			</div>
		</div>
	</div>
</CategoriaLayout>
