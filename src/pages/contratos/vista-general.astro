---
import CategoriaLayout from '../../layouts/CategoriaLayout.astro';
import IframePBI from '../../components/IframePBI.astro';
import { LucideInfo, LucideCalendar } from 'lucide-react';

const pbiUrl = "https://app.powerbi.com/view?r=eyJrIjoiNGRjNGE2MGYtMGJmZS00ODhhLWJlNjUtOWEzMzMwZTdkYTM4IiwidCI6IjhkMzY4MzZlLTZiNzUtNGRlNi1iYWI5LTVmNGIxNzc1NDI3ZiIsImMiOjR9&pageName=768ab1a4d46ee2e75522";
---

<CategoriaLayout 
	title="Vista General" 
	category="Contratos"
>
	<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
		<!-- Main Visualization -->
		<div class="lg:col-span-3">
			<div class="mb-8 flex items-center justify-between">
				<div class="flex items-center gap-4">
					<div class="px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-wider">
						Dashboard Interactivo
					</div>
					<div class="flex items-center gap-2 text-slate-400 text-sm">
						<LucideCalendar size={14} />
						Vigencia Actual
					</div>
				</div>
			</div>
			
			<IframePBI 
				src={pbiUrl} 
				title="Reporte de Vista General" 
			/>
			
			<div class="mt-8 prose prose-invert max-w-none">
				<h3 class="text-2xl font-heading font-bold mb-4">Análisis Contextual</h3>
				<p class="text-slate-300 leading-relaxed mb-4">
					Este reporte ofrece una visión general del estado de la contratación pública, consolidando los principales indicadores para un análisis rápido e integral.
				</p>
			</div>
		</div>
		
		<!-- Sidebar / Context -->
		<div class="space-y-6">
			<div class="p-6 rounded-2xl glass border border-white/5">
				<div class="flex items-center gap-2 mb-4 text-brand-primary">
					<LucideInfo size={20} />
					<h3 class="font-bold">Información</h3>
				</div>
				<div class="space-y-4">
					<div>
						<p class="text-xs font-bold text-slate-300 uppercase mb-1">Visión General</p>
						<p class="text-xs text-slate-500">Métricas clave de todos los contratos registrados en la plataforma.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</CategoriaLayout>
