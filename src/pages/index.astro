---
import Base from '../layouts/Base.astro';
import KpiCard from '../components/KpiCard.tsx';
import CategoryCard from '../components/CategoryCard.astro';
import { 
	LucideFileText, 
	LucideGraduationCap, 
	LucideHeartPulse, 
	LucideSearch, 
	LucideGlobe,
	LucideTrendingUp,
	LucideUsers,
	LucideBox
} from 'lucide-react';

const categories = [
	{
		title: 'Contratación Pública',
		description: 'Seguimiento en tiempo real de los procesos de SECOP I, II e Integrado.',
		href: '/contratos',
		icon: LucideFileText,
		color: '#6366f1'
	}
];
import RagAssistant from '../components/RagAssistant.tsx';
---

<Base>
	<main class="max-w-7xl mx-auto px-6 py-8">
		<!-- Hero -->
		<header class="text-center mb-10 relative flex flex-col items-center">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-brand-primary/20 blur-[120px] rounded-full -z-10 animate-pulse"></div>
			
			<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass border border-white/10 text-brand-primary text-xs font-bold mb-6">
				<span class="flex h-2 w-2 rounded-full bg-brand-primary animate-ping"></span>
				OBSERVATORIO NACIONAL DE DATOS
			</div>
			
			<h1 class="text-5xl md:text-6xl font-heading font-black mb-4 tracking-tighter leading-none">
				Civi<span class="text-gradient">Data</span>
			</h1>
			<p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
				Transformamos datos públicos en conocimiento ciudadano. Inteligencia de datos para una Colombia más transparente.
			</p>
		</header>

		<!-- KPIs -->
		<section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
			<KpiCard 
				client:load
				title="Contratos Analizados" 
				value={48311} 
				icon={LucideFileText}
				trend={{ value: 12, isPositive: true }}
			/>
			<KpiCard 
				client:load
				title="Departamentos" 
				value={34} 
				icon={LucideGlobe}
			/>
			<KpiCard 
				client:load
				title="Entidades Activas" 
				value={1240} 
				icon={LucideUsers}
				trend={{ value: 5, isPositive: true }}
			/>
			<KpiCard 
				client:load
				title="Valor Total (COP)" 
				value={4500000000} 
				prefix="$"
				icon={LucideTrendingUp}
				trend={{ value: 8, isPositive: true }}
			/>
		</section>

		<!-- Main Content: Category & Chat -->
		<section class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
			<!-- Left Column: Categories -->
			<div class="flex flex-col h-full">
				<div class="mb-6">
					<h2 class="text-3xl font-heading font-bold mb-2">Ejes Temáticos</h2>
					<p class="text-slate-400">Selecciona un área para profundizar en los datos y visualizaciones.</p>
				</div>
				
				<div class="grid grid-cols-1 gap-6">
					{categories.map(cat => (
						<CategoryCard {...cat} />
					))}
				</div>
			</div>

			<!-- Right Column: Chatbot -->
			<div class="h-full flex flex-col">
				<RagAssistant client:load />
			</div>
		</section>
		
		<footer class="mt-12 pt-8 border-t border-white/5 text-center text-slate-500 text-xs">
			<p>© 2026 CiviData. Proyecto de análisis de herramientas de datos públicos.</p>
		</footer>
	</main>
</Base>
