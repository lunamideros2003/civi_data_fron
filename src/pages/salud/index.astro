---
import CategoriaLayout from '../../layouts/CategoriaLayout.astro';
import IndicatorAccordion from '../../components/IndicatorAccordion.tsx';

const indicators = [
	{
		title: 'Cobertura de Vacunación',
		description: 'Seguimiento a los esquemas de vacunación por rango de edad y departamento.',
		href: '/salud/vacunacion'
	},
	{
		title: 'Gasto en Salud per Cápita',
		description: 'Análisis de la inversión pública en salud por habitante en las diferentes regiones.',
		href: '/salud/gasto'
	}
];
---

<CategoriaLayout 
	title="Salud Pública" 
	category="Salud"
	heroImage="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=2070"
>
	<div class="max-w-4xl">
		<div class="mb-12">
			<h2 class="text-3xl font-heading font-bold mb-4">Catálogo de Salud</h2>
			<p class="text-slate-400 text-lg">
				Métricas del sistema general de seguridad social y salud pública en Colombia.
			</p>
		</div>
		
		<IndicatorAccordion client:load items={indicators} />
	</div>
</CategoriaLayout>
